#Minimal Fe BCC — will be interrupted by SIGQUIT to test emergency dump
lattice body-centered Cubic 5.42
ion-species GBRV/$ID_lda.uspp
elec-cutoff 15 75
elec-ex-corr lda
ion Fe  0 0 0  0
kpoint-folding 1 1 1
elec-smearing Fermi 0.01
spintype z-spin
elec-initial-magnetization 3 no

#Many SCF iterations so we have time to send SIGQUIT
electronic-SCF nIterations 200

#Intentionally NO 'dump End State' — emergency dump should create .wfns anyway
dump End Forces
dump-name emergency.$VAR
